# Reciper — Environment Configuration
# Copy this file to .env and fill in your values. NEVER commit .env to git.

# Required: Your Google AI API key (supports Gemma 4 and Gemini models)
GEMINI_API_KEY="your_gemini_api_key_here"

# Optional: The URL where this app is hosted (used for CORS on the backend)
APP_URL="http://localhost:3000"
